rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isParticipant(data) {
      return signedIn() && request.auth.uid in data.participantIds;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.trustScore == 50.0
        && request.resource.data.completedSwaps == 0;
      allow update: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.trustScore == resource.data.trustScore
        && request.resource.data.completedSwaps == resource.data.completedSwaps
        && request.resource.data.ratingAverage == resource.data.ratingAverage
        && request.resource.data.ratingCount == resource.data.ratingCount;
    }

    match /needPosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.estimatedHours >= 1
        && request.resource.data.estimatedHours <= 8
        && request.resource.data.status == "OPEN";
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /swapOffers/{offerId} {
      allow read: if isParticipant(resource.data);
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.estimatedHours >= 1
        && request.resource.data.estimatedHours <= 8
        && request.resource.data.status == "PENDING";
      allow update: if isParticipant(resource.data)
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.estimatedHours == resource.data.estimatedHours
        && (
          request.resource.data.status in ["ACCEPTED", "REJECTED", "DISPUTED"]
          || (
            request.resource.data.status == "COMPLETED"
            && request.resource.data.fromConfirmedComplete == true
            && request.resource.data.toConfirmedComplete == true
          )
        );
    }

    match /chats/{chatId} {
      allow read, update: if isParticipant(resource.data);
      allow create: if signedIn() && request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      }
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && get(/databases/$(database)/documents/swapOffers/$(request.resource.data.swapOfferId)).data.status == "COMPLETED";
    }

    match /fraudSignals/{signalId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
